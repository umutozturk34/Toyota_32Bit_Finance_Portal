# ==============================================================================
# FINANCE PORTAL - ENVIRONMENT VARIABLES EXAMPLE
# Copy this file to '.env' and fill in your actual credentials.
# ==============================================================================

# --- API KEYS (Finance & News) ---
COINGECKO_KEY=YOUR_COINGECKO_KEY_HERE

# --- TRACKED ASSETS ---
# Runtime source is database table `tracked_assets` (seeded by Flyway migrations)

# --- DATABASE CONFIGURATION ---
DB_URL=jdbc:postgresql://localhost:5432/YOUR_DB_NAME
DB_USERNAME=YOUR_DB_USERNAME
DB_PASSWORD=YOUR_DB_PASSWORD

# --- IDENTITY & ACCESS MANAGEMENT (LDAP & KEYCLOAK) ---
LDAP_ADMIN_PASSWORD=YOUR_LDAP_ADMIN_PASSWORD
LDAP_CONFIG_PASSWORD=YOUR_LDAP_CONFIG_PASSWORD
KEYCLOAK_ADMIN_PASSWORD=YOUR_KEYCLOAK_ADMIN_PASSWORD
# finance-realm "admin" user login password; must satisfy realm passwordPolicy
# (8+ chars, upper + lower + digit + special char, not equal to username)
FINANCE_ADMIN_PASSWORD=YOUR_FINANCE_ADMIN_PASSWORD

# Redis credentials
REDIS_PASSWORD=REDIS_PASSWORD_HERE

# Notification microservice (v0.15)
NOTIFICATION_FROM_ADDRESS=noreply@finance.local

# OpenSearch credentials
OPENSEARCH_PASSWORD=OPENSEARCH_PASSWORD_HERE
OPENSEARCH_USERNAME=OPENSEARCH_USERNAME_HERE

# EVDS API Key
EVDS_API_KEY=YOUR_EVDS_API

# Frontend build args (Docker Compose → Dockerfile ARG)
VITE_API_BASE_URL=/api/v1
VITE_KEYCLOAK_URL=http://localhost/auth
VITE_KEYCLOAK_REALM=finance-realm
VITE_KEYCLOAK_CLIENT_ID=finance-frontend

# SonarQube (quality profile only; set before running `docker compose --profile quality up`)
SONAR_DB_PASSWORD=SONAR_DB_PASSWORD_HERE
SONAR_TOKEN=SONAR_TOKEN_HERE