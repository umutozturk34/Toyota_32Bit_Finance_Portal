# =============================================================================
#  Finance Portal — environment configuration
# =============================================================================
#  Quick start:   cp .env.example .env   and you are ready to go.
#
#  Every value below is a real, working local default, so the stack boots with
#  NO edits. These are demo credentials on purpose — change them for production.
#  The same .env works for BOTH startup modes (demo / empty).
#
#  Only the API keys in the first section are worth filling in — and even those
#  are OPTIONAL in demo mode, because the demo ships ~4 years of market data.
#  Add them when you want the app to keep fetching fresh data on its own.
# =============================================================================

# -----------------------------------------------------------------------------
#  External data API keys  (OPTIONAL — needed only for LIVE data refresh)
# -----------------------------------------------------------------------------
# EVDS = Turkish Central Bank series (deposit / inflation / FX). Free key:
#   https://evds2.tcmb.gov.tr  ->  register  ->  Profile  ->  API Key
EVDS_API_KEY=
# CoinGecko (crypto + precious metals). Free demo key, or leave blank for the
# public rate-limited tier:  https://www.coingecko.com/en/api
COINGECKO_KEY=
# TCMB forex XML feed — public, no key required.
TCMB_XML_URL=https://www.tcmb.gov.tr/kurlar/today.xml

# -----------------------------------------------------------------------------
#  Cold-start data fetch  (EMPTY mode only — demo mode is already seeded)
# -----------------------------------------------------------------------------
# On first boot against an EMPTY database the backend fetches years of history
# from the upstreams in dependency order (FX -> stocks -> commodities). This can
# take ~20-30 min (sometimes longer) depending on upstream rate limits.
# Set to false to skip it and fill the DB yourself via Admin -> Tasks.
# Source: backend/finance-app/src/main/java/com/finance/app/config/MarketDataInitializer.java
APP_MARKET_INIT_ENABLED=true

# -----------------------------------------------------------------------------
#  Login accounts  (known demo passwords — shown here on purpose)
# -----------------------------------------------------------------------------
# "admin" realm user (ADMIN + USER). Must satisfy the realm password policy:
# >=8 chars with upper + lower + digit + special.
FINANCE_ADMIN_PASSWORD=Admin123!
# "demouser" account — created ONLY in demo mode (realm-demo.json). Same policy.
DEMO_USER_PASSWORD=Demo123!
# Keycloak master admin (also used by the notification service admin client).
KEYCLOAK_ADMIN_PASSWORD=admin

# -----------------------------------------------------------------------------
#  Internal service credentials  (known demo values — change for production)
# -----------------------------------------------------------------------------
DB_PASSWORD=finance_pass
REDIS_PASSWORD=redis_pass
LDAP_ADMIN_PASSWORD=admin123
LDAP_CONFIG_PASSWORD=config123
# OpenSearch 2.x requires a strong password: >=8 chars, upper+lower+digit+special.
OPENSEARCH_USERNAME=admin
OPENSEARCH_PASSWORD=OpenSearch@2026

# -----------------------------------------------------------------------------
#  Frontend build args (baked into the Vite bundle at image build time)
# -----------------------------------------------------------------------------
VITE_API_BASE_URL=/api/v1
VITE_KEYCLOAK_URL=http://localhost/auth
VITE_KEYCLOAK_REALM=finance-realm
VITE_KEYCLOAK_CLIENT_ID=finance-frontend

# -----------------------------------------------------------------------------
#  Mail — clone-and-run uses Mailpit. Read captured mail at http://localhost:8025
# -----------------------------------------------------------------------------
NOTIFICATION_FROM_ADDRESS=noreply@finance.local
# Real SMTP (production / "deploy" mode). Leave the block blank to keep using Mailpit.
# These same vars also drive Keycloak's account emails (verify / 2FA / reset), so one
# block switches both. When set, do NOT run the Mailpit container (see README → Deployment).
# SPRING_MAIL_HOST=smtp.yourprovider.com
# SPRING_MAIL_PORT=587
# SPRING_MAIL_USERNAME=apikey-or-username
# SPRING_MAIL_PASSWORD=your-smtp-password
# SPRING_MAIL_PROPERTIES_MAIL_SMTP_AUTH=true
# SPRING_MAIL_PROPERTIES_MAIL_SMTP_STARTTLS_ENABLE=true

# -----------------------------------------------------------------------------
#  Public origin browsers reach the stack at (also used by Keycloak for redirects
#  and by the notification service for links in outgoing emails)
# -----------------------------------------------------------------------------
FRONTEND_BASE_URL=http://localhost

# -----------------------------------------------------------------------------
#  Internal URLs (already defaulted in docker-compose.yml — rarely changed)
# -----------------------------------------------------------------------------
PDF_SERVICE_URL=http://pdf-service:8080

# -----------------------------------------------------------------------------
#  Build — only needed to build images against PRIVATE GitHub Packages.
#  Leave blank: finance-common is compiled from source inside the Dockerfiles.
# -----------------------------------------------------------------------------
GITHUB_TOKEN=

# -----------------------------------------------------------------------------
#  Code-quality stack (only with `--profile quality`) — optional
# -----------------------------------------------------------------------------
SONAR_DB_PASSWORD=sonar_pass
SONAR_TOKEN=
