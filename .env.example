# ===========================================
# Finance Portal - Environment Configuration
# ===========================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env file to git!

# ===========================================
# External API Keys
# ===========================================

# NewsAPI - Business news (https://newsapi.org)
NEWSAPI_KEY=your_newsapi_key_here

# AlphaVantage - Stock data fallback (https://www.alphavantage.co)
ALPHAVANTAGE_KEY=your_alphavantage_key_here

# Twelve Data - Primary US stocks (https://twelvedata.com)
TWELVEDATA_KEY=your_twelvedata_key_here

# CoinGecko - Crypto and precious metals (https://www.coingecko.com)
COINGECKO_KEY=your_coingecko_key_here

# Tracked Cryptocurrencies - CoinGecko IDs (comma-separated)
TRACKED_CRYPTOS=bitcoin,ethereum,tether,binancecoin,solana,ripple,usd-coin,cardano,avalanche-2,dogecoin,tron,polkadot

# CollectAPI - BIST stocks and Turkish data (https://collectapi.com)
COLLECTAPI_KEY=your_collectapi_key_here

# BIST 30 Stocks - Borsa Istanbul symbols (comma-separated)
BIST_STOCKS=AEFES.IS,AKBNK.IS,ASELS.IS,BIMAS.IS,EKGYO.IS,ENKAI.IS,EREGL.IS,FROTO.IS,GARAN.IS,GUBRF.IS,ISCTR.IS,KCHOL.IS,KRDMD.IS,MGROS.IS,PETKM.IS,PGSUS.IS,SAHOL.IS,SASA.IS,SISE.IS,TAVHL.IS,TCELL.IS,THYAO.IS,TOASO.IS,TRALT.IS,TTKOM.IS,TUPRS.IS,ULKER.IS,YKBNK.IS

# ===========================================
# Database Configuration
# ===========================================

# PostgreSQL password for finance_user
# Used by: backend, keycloak
DB_PASSWORD=your_secure_db_password_here

# ===========================================
# LDAP Configuration
# ===========================================

# OpenLDAP admin password (cn=admin,dc=finance,dc=com)
LDAP_ADMIN_PASSWORD=your_secure_ldap_admin_password_here

# OpenLDAP config password
LDAP_CONFIG_PASSWORD=your_secure_ldap_config_password_here

# ===========================================
# Keycloak Configuration
# ===========================================

# Keycloak admin console password
# User: admin
KEYCLOAK_ADMIN_PASSWORD=your_secure_keycloak_admin_password_here

# Realm user passwords (for initial setup via configure-realm.sh)
# Admin user (admin@finance.com) - gets ADMIN + USER roles
REALM_ADMIN_PASSWORD=your_admin_user_password_here

# Test user (user@finance.com) - gets USER role
REALM_USER_PASSWORD=your_test_user_password_here

# ===========================================
# Security Notes
# ===========================================
# 
# 1. Generate strong passwords (16+ characters, mixed case, numbers, symbols)
# 2. Use different passwords for each service
# 3. Never commit .env to version control
# 4. Keep .env file permissions restricted (chmod 600 .env)
# 5. Rotate passwords regularly
# 6. Use a password manager to store these credentials
#
# Example strong password generation:
#   openssl rand -base64 32
#   or use: https://bitwarden.com/password-generator/
#
