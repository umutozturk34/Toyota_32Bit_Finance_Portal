# API Keys for Finance Portal
# Copy this file to .env and fill in your actual API keys

# NewsAPI - Business news
NEWSAPI_KEY=your_newsapi_key_here

# AlphaVantage - Stock data fallback
ALPHAVANTAGE_KEY=your_alphavantage_key_here

# Twelve Data - Primary US stocks
TWELVEDATA_KEY=your_twelvedata_key_here

# CoinGecko - Crypto and precious metals
COINGECKO_KEY=your_coingecko_key_here

# CollectAPI - BIST stocks and Turkish data
COLLECTAPI_KEY=your_collectapi_key_here

# Database credentials
DB_PASSWORD=finance_pass

# LDAP credentials  
LDAP_ADMIN_PASSWORD=admin123
LDAP_CONFIG_PASSWORD=config123

# Keycloak admin credentials
KEYCLOAK_ADMIN_PASSWORD=admin123
