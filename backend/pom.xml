<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
	<modelVersion>4.0.0</modelVersion>
	<parent>
		<groupId>org.springframework.boot</groupId>
		<artifactId>spring-boot-starter-parent</artifactId>
		<version>4.0.3</version>
		<relativePath/>
	</parent>
	<groupId>com.finance</groupId>
	<artifactId>finance-portal</artifactId>
	<version>0.0.1-SNAPSHOT</version>
	<name>Finance Portal</name>
	<description>Finance Portal - Multi Module</description>
	<packaging>pom</packaging>
	<properties>
		<java.version>21</java.version>
	</properties>

	<modules>
		<module>finance-common</module>
		<module>finance-cache</module>
		<module>finance-crypto</module>
		<module>finance-stock</module>
		<module>finance-forex</module>
		<module>finance-fund</module>
		<module>finance-user</module>
		<module>finance-app</module>
	</modules>

	<dependencyManagement>
		<dependencies>
			<dependency>
				<groupId>com.finance</groupId>
				<artifactId>finance-common</artifactId>
				<version>${project.version}</version>
			</dependency>
			<dependency>
				<groupId>com.finance</groupId>
				<artifactId>finance-cache</artifactId>
				<version>${project.version}</version>
			</dependency>
			<dependency>
				<groupId>com.finance</groupId>
				<artifactId>finance-crypto</artifactId>
				<version>${project.version}</version>
			</dependency>
			<dependency>
				<groupId>com.finance</groupId>
				<artifactId>finance-stock</artifactId>
				<version>${project.version}</version>
			</dependency>
			<dependency>
				<groupId>com.finance</groupId>
				<artifactId>finance-forex</artifactId>
				<version>${project.version}</version>
			</dependency>
			<dependency>
				<groupId>com.finance</groupId>
				<artifactId>finance-user</artifactId>
				<version>${project.version}</version>
			</dependency>
			<dependency>
				<groupId>com.finance</groupId>
				<artifactId>finance-fund</artifactId>
				<version>${project.version}</version>
			</dependency>
		</dependencies>
	</dependencyManagement>

	<dependencies>
		<dependency>
			<groupId>org.projectlombok</groupId>
			<artifactId>lombok</artifactId>
			<optional>true</optional>
		</dependency>
	</dependencies>

	<build>
		<plugins>
			<plugin>
				<groupId>org.apache.maven.plugins</groupId>
				<artifactId>maven-compiler-plugin</artifactId>
				<configuration>
					<annotationProcessorPaths>
						<path>
							<groupId>org.projectlombok</groupId>
							<artifactId>lombok</artifactId>
						</path>
					</annotationProcessorPaths>
				</configuration>
			</plugin>
		</plugins>
	</build>

</project>
